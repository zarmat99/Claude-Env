; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Valdombra"
config/description="2D top-down fantasy RPG. Data-driven, component-based. See docs/ai_memory/."
run/main_scene="res://scenes/main/Main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")

[autoload]

EventBus="*res://scripts/core/EventBus.gd"
DataRegistry="*res://scripts/core/DataRegistry.gd"
GameState="*res://scripts/core/GameState.gd"
FactionManager="*res://scripts/factions/FactionManager.gd"
ProgressionManager="*res://scripts/progression/ProgressionManager.gd"
SceneLoader="*res://scripts/core/SceneLoader.gd"
SaveManager="*res://scripts/core/SaveManager.gd"
InventoryManager="*res://scripts/inventory/InventoryManager.gd"
EquipmentManager="*res://scripts/equipment/EquipmentManager.gd"
CombatSystem="*res://scripts/combat/CombatSystem.gd"
SkillManager="*res://scripts/progression/SkillManager.gd"
EconomyManager="*res://scripts/economy/EconomyManager.gd"
QuestManager="*res://scripts/quest/QuestManager.gd"
DialogueManager="*res://scripts/dialogue/DialogueManager.gd"
SettingsManager="*res://scripts/core/SettingsManager.gd"
GameOverManager="*res://scripts/core/GameOverManager.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/stretch/mode="canvas_items"

