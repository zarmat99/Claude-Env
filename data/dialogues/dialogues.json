{
  "dialogue_fixture_actions": {
    "id": "dialogue_fixture_actions",
    "entry": "start",
    "nodes": {
      "start": {
        "speaker": "npc_fixture_guide",
        "text": "Fixture action node.",
        "actions": [
          { "type": "set_flag", "flag": "fixture_dialogue_started" },
          { "type": "give_item", "id": "item_fixture_consumable", "count": 2 },
          { "type": "take_item", "id": "item_fixture_consumable", "count": 1 },
          { "type": "give_reward", "rewards": { "xp": 5, "gold": 3, "items": [ { "id": "item_fixture_key", "count": 1 } ] } },
          { "type": "clear_flag", "flag": "fixture_dialogue_started" }
        ],
        "choices": [ { "text": "Done.", "next": null } ]
      }
    }
  },
  "dialogue_fixture_branch": {
    "id": "dialogue_fixture_branch",
    "entry": "start",
    "nodes": {
      "start": {
        "speaker": "npc_fixture_guide",
        "text": "Fixture branch node.",
        "actions": [ { "type": "start_quest", "quest": "quest_fixture_branch" } ],
        "choices": [
          {
            "text": "Choose branch one.",
            "next": null,
            "conditions": [
              { "type": "quest_stage_is", "quest": "quest_fixture_branch", "stage": 0 },
              { "type": "flag_not_set", "flag": "fixture_branch_two" }
            ],
            "actions": [
              { "type": "set_flag", "flag": "fixture_branch_one" },
              { "type": "set_quest_stage", "quest": "quest_fixture_branch", "stage": 100 }
            ]
          },
          {
            "text": "Choose branch two.",
            "next": null,
            "conditions": [
              { "type": "quest_stage_is", "quest": "quest_fixture_branch", "stage": 0 },
              { "type": "flag_not_set", "flag": "fixture_branch_one" }
            ],
            "actions": [
              { "type": "set_flag", "flag": "fixture_branch_two" },
              { "type": "set_quest_stage", "quest": "quest_fixture_branch", "stage": 200 }
            ]
          },
          { "text": "Leave.", "next": null }
        ]
      }
    }
  },
  "dialogue_fixture_reactive": {
    "id": "dialogue_fixture_reactive",
    "entry": "unknown",
    "entry_rules": [
      {
        "conditions": [ { "type": "flag_set", "flag": "fixture_known" } ],
        "node": "known"
      }
    ],
    "nodes": {
      "unknown": {
        "speaker": "npc_fixture_guide",
        "text": "Fixture unknown greeting.",
        "choices": [ { "text": "Leave.", "next": null } ]
      },
      "known": {
        "speaker": "npc_fixture_guide",
        "text": "Fixture known greeting.",
        "choices": [ { "text": "Leave.", "next": null } ]
      }
    }
  },
  "dialogue_fixture_guard": {
    "id": "dialogue_fixture_guard",
    "entry": "intro",
    "nodes": {
      "intro": {
        "speaker": "player",
        "text": "Fixture guarded intro.",
        "next": "deadend"
      },
      "deadend": {
        "speaker": "player",
        "text": "Fixture guarded dead end.",
        "choices": [
          {
            "text": "Unreachable.",
            "next": null,
            "conditions": [ { "type": "flag_set", "flag": "fixture_never_set" } ]
          }
        ]
      }
    }
  },
  "dialogue_fixture_trade": {
    "id": "dialogue_fixture_trade",
    "entry": "start",
    "nodes": {
      "start": {
        "speaker": "npc_fixture_merchant",
        "text": "Fixture trade node.",
        "choices": [
          {
            "text": "Buy fixture consumable.",
            "next": "start",
            "actions": [ { "type": "buy_item", "id": "item_fixture_consumable", "count": 1, "merchant": "merchant_fixture_basic" } ]
          },
          {
            "text": "Sell fixture weapon.",
            "next": "start",
            "conditions": [ { "type": "has_item", "target": "item_fixture_weapon", "count": 1 } ],
            "actions": [ { "type": "sell_item", "id": "item_fixture_weapon", "count": 1, "merchant": "merchant_fixture_basic" } ]
          },
          { "text": "Leave.", "next": null }
        ]
      }
    }
  }
}
